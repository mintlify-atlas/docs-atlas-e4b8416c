    "gpt-image -p <prompt>",
    "gpt-image -p <prompt> -i <image> [-m <mask>]",
    "gpt-image --size <1k|2k|4k|portrait|landscape|square|wide|tall>",
    "gpt-image --quality <auto|low|medium|high>",
    "gpt-image --format <png|jpeg|webp>",
    "gpt-image -n <count>",
    "gpt-image --background <auto|opaque>",
    "gpt-image --moderation <auto|low>",
    "client.images.generate(model='gpt-image-2', prompt=..., size=..., quality=...)",
    "client.images.edit(model='gpt-image-2', image=[...], prompt=..., mask=...)"
